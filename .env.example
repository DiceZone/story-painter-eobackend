# DiceNext 日志站后端 —— 本地/自建部署环境变量示例
# 复制为 .env 并按需修改；或直接用运行时环境变量。EdgeOne 部署无需本文件（用平台变量）。

# ── 通用 ─────────────────────────────────────────────
# 染色器（前端）地址，用于生成日志分享链接与 CORS 白名单。必填。
FRONTEND_URL=https://你的染色器域名
# 本地服务器监听端口（server.mjs）。默认 8787。
PORT=8787
# 日志保留天数，超期上传时后台清理。默认 30。
LOG_RETENTION_DAYS=30

# ── 存储后端选择 ──────────────────────────────────────
# sqlite（本地文件，零依赖）| s3（AWS S3/MinIO/COS-S3兼容）| cos（腾讯云 COS 原生）
# EdgeOne 部署留空即可（自动用全局 XBSKV）。
STORAGE_TYPE=sqlite

# ── SQLite（STORAGE_TYPE=sqlite）────────────────────
SQLITE_PATH=./data/logs.db

# ── S3 / S3 兼容（STORAGE_TYPE=s3；需 npm i @aws-sdk/client-s3）──
S3_BUCKET=my-dice-logs
S3_REGION=ap-east-1
# 自定义端点（MinIO / COS 的 S3 兼容端点）；AWS 官方留空
S3_ENDPOINT=
# MinIO 通常需要 true
S3_FORCE_PATH_STYLE=false
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PREFIX=dicelog/

# ── 腾讯云 COS（STORAGE_TYPE=cos；需 npm i cos-nodejs-sdk-v5）──
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=my-dice-logs-1250000000
COS_REGION=ap-guangzhou
COS_PREFIX=dicelog/

# ── 可选：上传备份桥（KV/存储失败时转发）────────────
BACKUP_UPLOAD_API=
